@page "/"
@inject HttpClient Http
@using frontend.Models

<PageTitle>Dashboard — Finance Tracker</PageTitle>

<h1 class="page-title">Dashboard</h1>
<p class="page-subtitle">Your financial overview at a glance</p>

@if (summary != null)
{
    <div class="summary-grid">
        <div class="summary-card income">
            <div class="summary-label">Total Income</div>
            <div class="summary-amount">+€@summary.Income.ToString("F2")</div>
            <div class="summary-count">@transactions?.Count(t => t.Type == "INCOME") transactions</div>
        </div>
        <div class="summary-card expense">
            <div class="summary-label">Total Expenses</div>
            <div class="summary-amount">-€@summary.Expense.ToString("F2")</div>
            <div class="summary-count">@transactions?.Count(t => t.Type == "EXPENSE") transactions</div>
        </div>
        <div class="summary-card balance">
            <div class="summary-label">Balance</div>
            <div class="summary-amount">€@summary.Balance.ToString("F2")</div>
            <div class="summary-count">@transactions?.Count total transactions</div>
        </div>
    </div>
}

@if (categories != null && categories.Any())
{
    <div class="section-header" style="margin-top:0">
        <span class="section-title">Spending by Category</span>
    </div>
    <div class="category-grid">
        @foreach (var cat in categories.OrderByDescending(c => c.Value))
        {
            var pct = summary?.Expense > 0
                ? (int)Math.Round(cat.Value / summary!.Expense * 100)
                : 0;
            <div class="category-card">
                <div class="category-top">
                    <span class="category-name">@cat.Key</span>
                    <span class="category-pct">@pct%</span>
                </div>
                <div class="category-bar-bg">
                    <div class="category-bar-fill" style="width:@pct%"></div>
                </div>
                <div class="category-amount">-€@cat.Value.ToString("F2")</div>
            </div>
        }
    </div>
}

<div class="section-header">
    <span class="section-title">Transactions</span>
    <a href="/add" class="btn-primary">＋ Add Transaction</a>
</div>

<div class="filter-tabs">
    <button class="filter-tab @(activeFilter == "ALL"     ? "active" : "")"
            @onclick='() => activeFilter = "ALL"'>All</button>
    <button class="filter-tab @(activeFilter == "INCOME"  ? "active" : "")"
            @onclick='() => activeFilter = "INCOME"'>Income</button>
    <button class="filter-tab @(activeFilter == "EXPENSE" ? "active" : "")"
            @onclick='() => activeFilter = "EXPENSE"'>Expenses</button>
</div>

@if (transactions == null)
{
    <p class="loading">Loading transactions...</p>
}
else if (!FilteredTransactions.Any())
{
    <div class="tx-table">
        <div class="empty-state">No transactions found.</div>
    </div>
}
else
{
    <div class="tx-table">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in FilteredTransactions)
                {
                    <tr>
                        <td><span class="tx-date">@FormatDate(t.Date)</span></td> 
                        <td>@t.Description</td>
                        <td>@t.Category</td>
                        <td><span class="badge @t.Type.ToLower()">@t.Type</span></td>
                        <td>
                            <span class="tx-amount @t.Type.ToLower()">
                                @(t.Type == "INCOME" ? "+" : "-")€@t.Amount.ToString("F2")
                            </span>
                        </td>
                        <td>
                            <button class="btn-danger-sm" @onclick="() => Delete(t.Id)">
                                remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Transaction>? transactions;
    private Summary? summary;
    private Dictionary<string, double>? categories;
    private string activeFilter = "ALL";

    private IEnumerable<Transaction> FilteredTransactions =>
        activeFilter == "ALL"
            ? transactions!
            : transactions!.Where(t => t.Type == activeFilter);

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        transactions = await Http.GetFromJsonAsync<List<Transaction>>("api/transactions");
        summary      = await Http.GetFromJsonAsync<Summary>("api/transactions/summary");
        categories   = await Http.GetFromJsonAsync<Dictionary<string, double>>("api/transactions/categories");
    }

    private async Task Delete(long id)
    {
        await Http.DeleteAsync($"api/transactions/{id}");
        await LoadData();
    }

    private string FormatDate(string date)
    {
    if (DateOnly.TryParse(date, out var d))
        return d.ToString("dd/MM/yyyy");
    return date;
    }
}