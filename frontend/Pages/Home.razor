@namespace frontend.Pages
@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@inject BudgetService BudgetService
@inject SavingsGoalService SavingsGoalService
@using frontend.Layout

<PageTitle>Finance Tracker</PageTitle>

<h1 class="page-title">Dashboard</h1>
<p class="page-subtitle">Your financial overview at a glance</p>

@if (summary != null)
{
    <div class="summary-grid">
        <div class="summary-card income">
            <div class="summary-label">Total Income</div>
            <div class="summary-amount">+EUR @FormatNumber(summary.Income)</div>
            <div class="summary-count">@(transactions?.Count(t => t.Type == "INCOME") ?? 0) transactions</div>
        </div>
        <div class="summary-card expense">
            <div class="summary-label">Total Expenses</div>
            <div class="summary-amount">-EUR @FormatNumber(summary.Expense)</div>
            <div class="summary-count">@(transactions?.Count(t => t.Type == "EXPENSE") ?? 0) transactions</div>
        </div>
        <div class="summary-card balance">
            <div class="summary-label">Balance</div>
            <div class="summary-amount">EUR @FormatNumber(summary.Balance)</div>
            <div class="summary-count">@(transactions?.Count ?? 0) total transactions</div>
        </div>
    </div>
}

@if (barItems.Any() || donutSlices.Any())
{
    <div class="charts-row">

        @if (barItems.Any())
        {
            <div class="chart-card">
                <div class="chart-card-title">Monthly overview</div>
                <svg viewBox="0 0 490 220" class="bar-chart-svg">
                    @foreach (var tick in yTicks)
                    {
                        <line x1="48" y1="@tick.Y" x2="485" y2="@tick.Y" class="chart-grid-line" />
                        @SvgText("44", tick.LabelY, "chart-axis-label", tick.Label, "end")
                    }
                    <line x1="48" y1="175" x2="485" y2="175" class="chart-base-line" />
                    @foreach (var bar in barItems)
                    {
                        <rect x="@bar.IncomeX" y="@bar.IncomeY" width="@bar.BarW" height="@bar.IncomeH" class="bar-income" rx="3">
                            <title>+EUR @FormatNumber(bar.IncomeValue, "F2")</title>
                        </rect>
                        <rect x="@bar.ExpenseX" y="@bar.ExpenseY" width="@bar.BarW" height="@bar.ExpenseH" class="bar-expense" rx="3">
                            <title>-EUR @FormatNumber(bar.ExpenseValue, "F2")</title>
                        </rect>
                        @SvgText(bar.LabelX, "190", "chart-axis-label", bar.Label, "middle")
                    }
                    <rect x="52" y="205" width="9" height="9" class="bar-income" rx="2" />
                    @SvgText("64", "213", "chart-axis-label", "Income")
                    <rect x="110" y="205" width="9" height="9" class="bar-expense" rx="2" />
                    @SvgText("122", "213", "chart-axis-label", "Expenses")
                </svg>
            </div>
        }

        @if (donutSlices.Any())
        {
            <div class="chart-card">
                <div class="chart-card-title">Spending by category</div>
                <svg viewBox="0 0 220 200" class="donut-svg">
                    @foreach (var slice in donutSlices)
                    {
                        <path d="@slice.Path" fill="@slice.Color" class="donut-segment">
                            <title>@slice.Category: EUR @FormatNumber(slice.Amount, "F2") (@slice.PctText)</title>
                        </path>
                    }
                </svg>
                <div class="donut-legend">
                    @foreach (var slice in donutSlices)
                    {
                        <div class="donut-legend-row">
                            <span class="donut-dot" style="background-color:@slice.Color"></span>
                            <span class="donut-cat">@slice.Category</span>
                            <span class="donut-pct">@slice.PctText</span>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
}

<div class="section-header">
    <span class="section-title">Transactions</span>
    <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
        <button class="btn-ghost" @onclick="ExportCsv" disabled="@isExporting">
            @if (isExporting)
            {
                <span>Exporting...</span>
                <Skeleton Type="rect" Width="20" Height="16" CssClass="ms-2" />
            }
            else
            {
                @:Export CSV
            }
        </button>

        <!-- Search Box -->
        <div style="display:flex;align-items:center;gap:0.5rem;min-width:200px;">
            <input type="text"
                   class="form-control"
                   placeholder="Search transactions..."
                   @bind="searchTerm"
                   @bind:event="oninput"
                   style="width:200px;" />
        </div>

        <!-- Sort Dropdown -->
        <div style="display:flex;align-items:center;gap:0.5rem;">
            <label class="form-label" style="margin-bottom:0;">Sort by:</label>
            <select class="form-select"
                    @bind="sortBy"
                    @bind:event="onchange"
                    style="width:100px;">
                <option value="date">Date</option>
                <option value="amount">Amount</option>
                <option value="description">Description</option>
                <option value="category">Category</option>
            </select>

            <button class="btn-ghost"
                    @onclick="() => sortDescending = !sortDescending"
                    style="width:30px;height:28px;padding:0;display:flex;align-items:center;justify-content:center;">
                @if (sortDescending)
                {
                    <span>▼</span>
                }
                else
                {
                    <span>▲</span>
                }
            </button>
        </div>

        <a href="/add" class="btn-primary">Add Transaction</a>
    </div>
</div>

<div class="filter-bar">
    <div class="filter-tabs">
        <button class="filter-tab @(activeFilter == "ALL" ? "active" : "")" @onclick='() => activeFilter = "ALL"'>All</button>
        <button class="filter-tab @(activeFilter == "INCOME" ? "active" : "")" @onclick='() => activeFilter = "INCOME"'>Income</button>
        <button class="filter-tab @(activeFilter == "EXPENSE" ? "active" : "")" @onclick='() => activeFilter = "EXPENSE"'>Expenses</button>
    </div>
    <div class="date-range">
        <input type="text" class="form-control date-input"
               @bind="filterFrom" @bind:format="dd/MM/yyyy"
               placeholder="From DD/MM/YYYY" />
        <span class="date-sep">to</span>
        <input type="text" class="form-control date-input"
               @bind="filterTo" @bind:format="dd/MM/yyyy"
               placeholder="To DD/MM/YYYY" />
        @if (filterFrom.HasValue || filterTo.HasValue)
        {
            <button class="btn-ghost" style="padding:0.35rem 0.75rem;font-size:0.8rem;"
                    @onclick="ClearDateFilter" disabled="@isClearingFilter">
                @if (isClearingFilter)
                {
                    <span>Clearing...</span>
                    <Skeleton Type="rect" Width="20" Height="16" CssClass="ms-2" />
                }
                else
                {
                    @:Clear
                }
            </button>
        }
    </div>
</div>

@if (isLoading)
{
    <div class="skeleton-loader">
        <!-- Summary Cards Skeletons -->
        <div class="summary-grid">
            <div class="summary-card">
                <Skeleton Type="rect" Width="100" Height="4" WidthIsPercent="true" />
                <Skeleton Type="rect" Width="60" Height="24" WidthIsPercent="true" CssClass="mt-2" />
                <Skeleton Type="rect" Width="40" Height="16" WidthIsPercent="true" CssClass="mt-1" />
            </div>
            <div class="summary-card">
                <Skeleton Type="rect" Width="100" Height="4" WidthIsPercent="true" />
                <Skeleton Type="rect" Width="60" Height="24" WidthIsPercent="true" CssClass="mt-2" />
                <Skeleton Type="rect" Width="40" Height="16" WidthIsPercent="true" CssClass="mt-1" />
            </div>
            <div class="summary-card">
                <Skeleton Type="rect" Width="100" Height="4" WidthIsPercent="true" />
                <Skeleton Type="rect" Width="60" Height="24" WidthIsPercent="true" CssClass="mt-2" />
                <Skeleton Type="rect" Width="40" Height="16" WidthIsPercent="true" CssClass="mt-1" />
            </div>
        </div>

        <!-- Charts Skeletons -->
        <div class="charts-row">
            <div class="chart-card">
                <div class="chart-card-title">
                    <Skeleton Type="rect" Width="50" Height="16" WidthIsPercent="true" CssClass="mb-2" />
                </div>
                <div class="chart-placeholder">
                    <Skeleton Type="rect" Width="100" Height="180" WidthIsPercent="true" />
                </div>
            </div>
            <div class="chart-card">
                <div class="chart-card-title">
                    <Skeleton Type="rect" Width="50" Height="16" WidthIsPercent="true" CssClass="mb-2" />
                </div>
                <div class="chart-placeholder">
                    <Skeleton Type="rect" Width="100" Height="180" WidthIsPercent="true" />
                </div>
            </div>
        </div>

        <!-- Transaction List Skeletons -->
        <div class="section-header">
            <span class="section-title">
                <Skeleton Type="rect" Width="30" Height="16" WidthIsPercent="true" />
            </span>
            <div style="display:flex;gap:0.75rem;align-items:center;">
                <button class="btn-ghost" disabled>
                    <Skeleton Type="rect" Width="80" Height="28" />
                </button>
                <a href="/add" class="btn-primary" disabled>
                    <Skeleton Type="rect" Width="100" Height="28" />
                </a>
            </div>
        </div>

        <div class="filter-bar">
            <div class="filter-tabs">
                <button class="filter-tab" disabled>
                    <Skeleton Type="rect" Width="40" Height="28" />
                </button>
                <button class="filter-tab" disabled>
                    <Skeleton Type="rect" Width="60" Height="28" />
                </button>
                <button class="filter-tab" disabled>
                    <Skeleton Type="rect" Width="60" Height="28" />
                </button>
            </div>
            <div class="date-range">
                <input type="text" class="form-control date-input" disabled placeholder="From DD/MM/YYYY" />
                <span class="date-sep">to</span>
                <input type="text" class="form-control date-input" disabled placeholder="To DD/MM/YYYY" />
            </div>
        </div>

        <div class="tx-table">
            <table>
                <thead>
                    <tr>
                        <th><Skeleton Type="rect" Width="80" Height="16" /></th>
                        <th><Skeleton Type="rect" Width="150" Height="16" /></th>
                        <th><Skeleton Type="rect" Width="100" Height="16" /></th>
                        <th><Skeleton Type="rect" Width="60" Height="16" /></th>
                        <th><Skeleton Type="rect" Width="80" Height="16" /></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < 5; i++)
                    {
                        <tr>
                            <td><Skeleton Type="rect" Width="80" Height="16" /></td>
                            <td><Skeleton Type="rect" Width="150" Height="16" /></td>
                            <td><Skeleton Type="rect" Width="100" Height="16" /></td>
                            <td><Skeleton Type="rect" Width="60" Height="16" /></td>
                            <td><Skeleton Type="rect" Width="80" Height="16" /></td>
                            <td></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="tx-table"><div class="empty-state">@loadError</div></div>
}
else if (!FilteredTransactions.Any())
{
    <div class="tx-table">
        <div class="empty-state">
            @if ((transactions?.Count ?? 0) == 0)
            {
                <div class="empty-state-illustration">
                    <div class="empty-state-icon">📊</div>
                    <h3>No transactions yet</h3>
                    <p>Start by adding your first transaction to see your financial overview.</p>
                    <a href="/add" class="btn-primary mt-3">Add First Transaction</a>
                </div>
            }
            else
            {
                <div class="empty-state-illustration">
                    <div class="empty-state-icon">🔍</div>
                    <h3>No transactions found</h3>
                    <p>Try adjusting your filters to see transactions.</p>
                    <button class="btn-ghost mt-3" @onclick="ClearDateFilter">Clear Filters</button>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="tx-table">
        <table>
            <thead>
                <tr>
                    <th>Date</th><th>Description</th><th>Category</th>
                    <th>Type</th><th>Amount</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in FilteredTransactions)
                {
                    <tr>
                        <td><span class="tx-date">@FormatDate(t.Date)</span></td>
                        <td>@t.Description</td>
                        <td>@t.Category</td>
                        <td><span class="badge @t.Type.ToLowerInvariant()">@t.Type</span></td>
                        <td>
                            <span class="tx-amount @t.Type.ToLowerInvariant()">
                                @(t.Type == "INCOME" ? "+" : "-")EUR @FormatNumber(t.Amount)
                            </span>
                        </td>
                        <td class="tx-actions">
                            <a href="/edit/@t.Id" class="btn-edit">Edit</a>
                            <button class="btn-danger-sm" @onclick="() => ConfirmDelete(t.Id)" disabled="@(deletingTransactionId == t.Id)">
                                @if (deletingTransactionId == t.Id)
                                {
                                    <span>Removing...</span>
                                    <Skeleton Type="rect" Width="20" Height="16" CssClass="ms-2" />
                                }
                                else
                                {
                                    @:Remove
                                }
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
